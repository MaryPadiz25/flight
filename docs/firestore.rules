rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function myRole() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role; }
    function isAdmin() { return signedIn() && myRole() == 'admin'; }
    function isInstructor() { return signedIn() && myRole() == 'instructor'; }
    function isStudent() { return signedIn() && myRole() == 'student'; }

    match /users/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin() || isInstructor());
      allow create: if signedIn() && request.auth.uid == uid; // sign-up writes their own profile
      allow update: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /aircraft/{id} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /maintenanceBlocks/{id} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /availability/{id} {
      allow read: if signedIn();
      allow write: if isAdmin() || isInstructor();
    }

    match /bookings/{id} {
      allow read: if signedIn() && (
        isAdmin() ||
        resource.data.studentId == request.auth.uid ||
        resource.data.instructorId == request.auth.uid
      );
      allow create: if isStudent() && request.resource.data.studentId == request.auth.uid
                    || isAdmin();
      allow update: if isAdmin() ||
        (isInstructor() && resource.data.instructorId == request.auth.uid) ||
        (isStudent() && resource.data.studentId == request.auth.uid &&
          request.resource.data.status == 'cancelled'); // students can only request cancellation
      allow delete: if isAdmin();
    }

    match /payments/{id} {
      allow read: if signedIn() && (isAdmin() || resource.data.studentId == request.auth.uid);
      allow write: if isAdmin(); // Stripe webhook (Cloud Function w/ admin SDK) writes these
    }
  }
}
